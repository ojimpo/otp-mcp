# OTP (OpenTripPlanner) のGraphQLベースURL
# arigatai-score の docker compose で動くOTPに同一ネットワークから繋ぐ場合は http://otp:8080
OTP_BASE_URL=http://otp:8080

# トランスポート: "http"（claude.ai / リモート用）または "stdio"（Claude Code / Desktop用、デフォルト）
TRANSPORT=http

# HTTPサーバーのポート（TRANSPORT=http のときのみ）
PORT=3000

# 任意: HTTPエンドポイントのBearer認証トークン（リモート公開時は設定推奨）
MCP_AUTH_TOKEN=

# 任意: ツール説明に出すサービスラベル
# SERVICE_LABEL=self-hosted OTP (Kanto)

# 任意: ツール名のサフィックス（複数インスタンスを区別したいとき）
# OTP_TOOL_SUFFIX=
